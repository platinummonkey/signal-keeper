{
  "name": "signal-keeper",
  "version": "0.1.0",
  "description": "Automated GitHub PR reviewer with Claude Code AI and browser UI",
  "license": "MIT",
  "type": "module",
  "bin": {
    "signal-keeper": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup && vite build && chmod +x dist/index.js",
    "build:client": "vite build",
    "build:server": "tsup && chmod +x dist/index.js",
    "dev": "tsx src/index.ts start --dev",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc -p src/client/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "better-sqlite3": "^12.9.0",
    "commander": "^12.0.0",
    "express": "^5.2.1",
    "node-notifier": "^10.0.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "yaml": "^2.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/node-notifier": "^8.0.5",
    "tsup": "^8.5.1",
    "tsx": "^4.7.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "esbuild": ">=0.25.0"
  }
}