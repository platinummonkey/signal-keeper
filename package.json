{
  "name": "signal-keeper",
  "version": "0.1.0",
  "description": "Automated GitHub PR reviewer with Claude Code AI and browser UI",
  "type": "module",
  "bin": {
    "signal-keeper": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup && vite build && chmod +x dist/index.js",
    "build:client": "vite build",
    "build:server": "tsup && chmod +x dist/index.js",
    "dev": "tsx src/index.ts start --dev",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc -p src/client/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@octokit/rest": "^21.0.0",
    "better-sqlite3": "^11.0.0",
    "commander": "^12.0.0",
    "express": "^4.19.0",
    "node-notifier": "^10.0.1",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "yaml": "^2.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@types/node-notifier": "^8.0.5",
    "tsup": "^8.5.1",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "esbuild": ">=0.25.0"
  }
}
